# provisionar.sh — variáveis de ambiente necessárias
# Copie para .env e preencha antes de rodar o script

# Banco master
AURA_MASTER_DB_URL=postgresql://postgres:SENHA@localhost:5432/aura_master
AURA_DB_SUPERUSER=postgres
AURA_DB_CONTAINER=supabase-db

# Traefik (nome do volume de config dinâmica)
AURA_TRAEFIK_CONFIG_VOL=traefik-config

# AuraZap / WAHA Orchestrator
AURA_WAHA_ORCH_URL=http://localhost:4000
AURA_WAHA_ORCH_TOKEN=c8699281-fe73-439a-80f4-fa11684eb000

# Domínio base
AURA_DOMAIN=aurabr.app

# Base URL do webhook n8n para eventos WhatsApp
AURA_WEBHOOK_BASE=https://n8n.srv885928.hstgr.cloud/webhook
